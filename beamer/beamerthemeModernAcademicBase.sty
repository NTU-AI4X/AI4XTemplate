    \setlength{\MA@frametitle@usedheight}{\MA@frametitle@compactheight}%
    \setlength{\MA@frametitle@useddepth}{\MA@frametitle@compactdepth}%
    \setlength{\MA@frametitle@textwidth}{\dimexpr\paperwidth-\MA@contentpage@headerleftmargin-\MA@contentpage@headerrightmargin\relax}%
  \fi
}

