\long\def\MA@splitacademicheader#1\headerlogo#2#3\MA@stop{%
  \renewcommand{\MA@header@before}{#1}%
  \renewcommand{\MA@header@logo}{#2}%
  \renewcommand{\MA@header@test}{#2}%
  \ifx\MA@header@test\MA@header@nologovalue
    \MA@header@haslogofalse
    \renewcommand{\MA@header@logo}{}%
    \renewcommand{\MA@header@after}{}%
  \else
    \MA@header@haslogotrue
    \MA@stripacademicheadertrail#3\MA@stop
  \fi
}
\newcommand{\MA@renderacademicheader}[1]{%
  \MA@splitacademicheader#1\headerlogo{\MA@header@nologomarker}\MA@stop
  \MA@setlayoutcontentwidth{\MA@contentpage@headerleftmargin}{\MA@contentpage@headerrightmargin}%
  \vbox to \MA@frametitle@boxareaheight{%
    \vskip\MA@frametitle@topskip
    \hbox to \paperwidth{%
      \hspace*{\MA@contentpage@headerleftmargin}%
      \ifMA@header@haslogo
        \ifblank{\MA@header@before}{%
          \begin{minipage}[c][\dimexpr\MA@frametitle@boxareaheight-\MA@frametitle@topskip\relax][c]{0.26\MA@layout@contentwidth}
            \raggedright
            \MA@header@logo
          \end{minipage}%
          \hfill
          \begin{minipage}[c][\dimexpr\MA@frametitle@boxareaheight-\MA@frametitle@topskip\relax][c]{0.68\MA@layout@contentwidth}
            \raggedleft
            \MA@header@after
          \end{minipage}%
        }{%
          \begin{minipage}[c][\dimexpr\MA@frametitle@boxareaheight-\MA@frametitle@topskip\relax][c]{0.68\MA@layout@contentwidth}
            \raggedright
            \MA@header@before
          \end{minipage}%
          \hfill
          \begin{minipage}[c][\dimexpr\MA@frametitle@boxareaheight-\MA@frametitle@topskip\relax][c]{0.26\MA@layout@contentwidth}
            \raggedleft
            \MA@header@logo
          \end{minipage}%
        }%
      \else
        \begin{minipage}[c][\dimexpr\MA@frametitle@boxareaheight-\MA@frametitle@topskip\relax][c]{\MA@layout@contentwidth}
          \raggedright
          \MA@header@before
        \end{minipage}%
      \fi
      \hspace*{\MA@contentpage@headerrightmargin}%
    }%
    \vfil
  }%
}
\NewDocumentEnvironment{academicheader}{+b}{\MA@renderacademicheader{#1}}{}
\NewDocumentEnvironment{academicbody}{+b}{%
  \MA@setlayoutregions{\MA@contentpage@headerratio}{\MA@contentpage@bodyratio}{\MA@contentpage@footerratio}%
  \MA@setlayoutcontentwidth{\MA@contentpage@bodyleftmargin}{\MA@contentpage@bodyrightmargin}%
  \begin{minipage}[t][\MA@layout@bodyheight][t]{\MA@layout@contentwidth}
    #1%
  \end{minipage}%
}{}
\NewDocumentEnvironment{academicfooter}{+b}{%
  \MA@setlayoutcontentwidth{\MA@contentpage@footerleftmargin}{\MA@contentpage@footerrightmargin}%
  \hbox to \paperwidth{%
    \hspace*{\MA@contentpage@footerleftmargin}%
    \begin{minipage}[c][\MA@layout@footerheight][c]{\MA@layout@contentwidth}
      #1%
    \end{minipage}%
    \hspace*{\MA@contentpage@footerrightmargin}%
  }%
}{}

\newcommand{\MA@displaytitle}{%
  \ifx\MA@shorttitle\@empty
    \insertshorttitle
  \else
    \MA@shorttitle
  \fi
}
\newcommand{\MA@displayauthor}{%
  \ifx\MA@shortauthor\@empty
    \insertshortauthor
  \else
    \MA@shortauthor
  \fi
}

%% ============================================================================
%% 4. BEAMER STYLE
%% ============================================================================

\mode<presentation>

\usefonttheme{professionalfonts}
\setbeamersize{text margin left=\MA@slide@leftmargin,text margin right=\MA@slide@rightmargin}
\beamertemplatenavigationsymbolsempty
\MA@applybeamercolors

\setbeamerfont{title}{family=\sffamily,series=\bfseries,size=\LARGE}
\setbeamerfont{subtitle}{family=\sffamily,series=\mdseries,size=\normalsize}
\setbeamerfont{author}{family=\sffamily,series=\mdseries,size=\small}
\setbeamerfont{institute}{family=\sffamily,series=\mdseries,size=\footnotesize}
\setbeamerfont{date}{family=\sffamily,series=\mdseries,size=\footnotesize}
\setbeamerfont{frametitle}{family=\sffamily,series=\bfseries,size=\large}
\setbeamerfont{framesubtitle}{family=\sffamily,series=\mdseries,size=\scriptsize}
\setbeamerfont{footline}{family=\sffamily,size=\scriptsize}
\setbeamerfont{block title}{family=\sffamily,series=\bfseries,size=\normalsize}
\setbeamerfont{block body}{size=\small}
\setbeamerfont{caption}{size=\scriptsize}

\setbeamertemplate{itemize item}{%
  \raise0.18ex\hbox{\color{academicblue}\rule{0.62ex}{0.62ex}}%
}
\setbeamertemplate{itemize subitem}{%
  \raise0.22ex\hbox{\color{academicblue!70}\rule{0.48ex}{0.48ex}}%
}
\setbeamertemplate{enumerate item}{%
  \usebeamercolor[fg]{structure}\insertenumlabel.%
}
\setbeamertemplate{caption}[numbered]
\setbeamertemplate{blocks}[rounded][shadow=false]
\setbeamertemplate{theorems}[numbered]

%% ============================================================================
%% 5. TITLE PAGE, FRAME TITLE, FOOTLINE, AND SECTION PAGES
%% ============================================================================

\setbeamertemplate{title page}{%
  \MA@setlayoutregions{\MA@titlepage@headerratio}{\MA@titlepage@bodyratio}{\MA@titlepage@footerratio}%
  \MA@setlayoutcontentwidth{\MA@titlepage@headerleftmargin}{\MA@titlepage@headerrightmargin}%
  \begin{tikzpicture}[remember picture,overlay]
    \fill[MA@canvas] (current page.south west) rectangle (current page.north east);
    \fill[academicblue] (current page.north west) rectangle ([xshift=3.2mm]current page.south west);
    \ifMA@titlepage@header
      \draw[academicblue!22,line width=0.6pt]
        ([xshift=\MA@titlepage@headerleftmargin,yshift=-\MA@layout@headerheight]current page.north west) --
        ([xshift=-\MA@titlepage@headerrightmargin,yshift=-\MA@layout@headerheight]current page.north east);
    \fi
    \ifMA@titlepage@footer
      \MA@setlayoutcontentwidth{\MA@titlepage@footerleftmargin}{\MA@titlepage@footerrightmargin}%
      \draw[MA@softline,line width=0.45pt]
        ([xshift=\MA@titlepage@footerleftmargin,yshift=\MA@layout@footerheight]current page.south west) --
        ([xshift=-\MA@titlepage@footerrightmargin,yshift=\MA@layout@footerheight]current page.south east);
      \node[anchor=south west,inner sep=0pt]
        at ([xshift=\MA@titlepage@footerleftmargin]current page.south west) {%
          \begin{minipage}[c][\MA@layout@footerheight][c]{\MA@layout@contentwidth}
            {\usebeamerfont{footline}\color{MA@muted}\MA@displayauthor\hfill\MA@displaytitle\par}%
          \end{minipage}%
        };
    \fi
    \ifMA@logointitle
      \ifx\MA@titlelogo\@empty\else
        \node[anchor=south east,inner sep=0pt]
          at ([xshift=-\MA@titlepage@bodyrightmargin,yshift=\dimexpr\MA@layout@footerheight+\MA@titlepage@bodyrightmargin\relax]current page.south east) {%
            \MA@titlelogo%
          };
      \fi
    \fi
  \end{tikzpicture}%
  \vspace*{\MA@layout@headerheight}%
  \MA@setlayoutcontentwidth{\MA@titlepage@bodyleftmargin}{\MA@titlepage@bodyrightmargin}%
  \hspace*{\MA@titlepage@bodyleftmargin}%
  \begin{minipage}[c][\MA@layout@bodyheight][c]{\MA@layout@contentwidth}
    \raggedright
    {\usebeamerfont{title}\usebeamercolor[fg]{title}\inserttitle\par}
    \ifx\insertsubtitle\@empty\else
      \vspace{0.45em}
      {\usebeamerfont{subtitle}\usebeamercolor[fg]{subtitle}\insertsubtitle\par}
    \fi
    \vspace{1.5em}
    {\usebeamerfont{author}\usebeamercolor[fg]{author}\insertauthor\par}
    \ifx\insertinstitute\@empty\else
      \vspace{0.35em}
      {\usebeamerfont{institute}\usebeamercolor[fg]{institute}\insertinstitute\par}
    \fi
    \ifx\MA@email\@empty\else
      \vspace{0.25em}
      {\usebeamerfont{institute}\color{MA@muted}\texttt{\MA@email}\par}
    \fi
    \ifx\insertdate\@empty\else
      \vspace{0.75em}
      {\usebeamerfont{date}\usebeamercolor[fg]{date}\insertdate\par}
    \fi
  \end{minipage}%
}

\setbeamertemplate{frametitle}{%
  \ifMA@contentpage@header
    \MA@setlayoutregions{\MA@contentpage@headerratio}{\MA@contentpage@bodyratio}{\MA@contentpage@footerratio}%
    \MA@syncframetitledimensions
    \setlength{\MA@frametitle@boxareaheight}{\dimexpr\MA@layout@headerheight-\MA@frametitle@outertopskip\relax}%
    \ifdim\MA@frametitle@boxareaheight<2mm
      \setlength{\MA@frametitle@boxareaheight}{\MA@layout@headerheight}%
    \fi
    \nointerlineskip
    \vspace*{\MA@frametitle@outertopskip}%
    \begin{beamercolorbox}[
        wd=\paperwidth,
        ht=\dimexpr\MA@frametitle@boxareaheight-\MA@frametitle@subtitleextra\relax,
        dp=\MA@frametitle@subtitleextra
      ]{frametitle}
      \ifMA@logoinheader
        \ifx\MA@titlelogo\@empty
          \begin{academicheader}
            {\usebeamerfont{frametitle}\usebeamercolor[fg]{frametitle}\insertframetitle\par}%
            \ifx\insertframesubtitle\@empty\else
              \vspace{0.15em}%
              {\usebeamerfont{framesubtitle}\usebeamercolor[fg]{framesubtitle}\insertframesubtitle\par}%
            \fi
          \end{academicheader}%
        \else
          \begin{academicheader}
            {\usebeamerfont{frametitle}\usebeamercolor[fg]{frametitle}\insertframetitle\par}%
            \ifx\insertframesubtitle\@empty\else
              \vspace{0.15em}%
              {\usebeamerfont{framesubtitle}\usebeamercolor[fg]{framesubtitle}\insertframesubtitle\par}%
            \fi
            \headerlogo{\raisebox{-0.25\height}{\MA@titlelogo}}%
          \end{academicheader}%
        \fi
      \else
        \begin{academicheader}
          {\usebeamerfont{frametitle}\usebeamercolor[fg]{frametitle}\insertframetitle\par}%
          \ifx\insertframesubtitle\@empty\else
            \vspace{0.15em}%
            {\usebeamerfont{framesubtitle}\usebeamercolor[fg]{framesubtitle}\insertframesubtitle\par}%
          \fi
        \end{academicheader}%
      \fi
    \end{beamercolorbox}%
    \begin{tikzpicture}[remember picture,overlay]
      \draw[academicblue!18,line width=0.5pt]
        ([xshift=\MA@contentpage@headerleftmargin,yshift=-\MA@layout@headerheight]current page.north west) --
        ([xshift=-\MA@contentpage@headerrightmargin,yshift=-\MA@layout@headerheight]current page.north east);
    \end{tikzpicture}%
  \fi
}

\newenvironment{academicframe}[2][]{%
  \begin{frame}[environment=academicframe]%
  \frametitle{#2}%
  \ifstrempty{#1}{}{\framesubtitle{#1}}%
}{%
  \end{frame}%
}
\newenvironment{modernacademicframe}[2][]{%
  \begin{frame}[environment=modernacademicframe]%
  \frametitle{#2}%
  \ifstrempty{#1}{}{\framesubtitle{#1}}%
}{%
  \end{frame}%
}

\setbeamertemplate{footline}{%
  \ifMA@contentpage@footer
    \MA@setlayoutregions{\MA@contentpage@headerratio}{\MA@contentpage@bodyratio}{\MA@contentpage@footerratio}%
    \setlength{\MA@footline@useddepth}{\MA@footline@depth}%
    \setlength{\MA@footline@usedheight}{\dimexpr\MA@layout@footerheight-\MA@footline@useddepth\relax}%
    \leavevmode
    \begin{tikzpicture}[remember picture,overlay]
      \draw[MA@softline,line width=0.45pt]
        ([xshift=\MA@contentpage@footerleftmargin,yshift=\MA@layout@footerheight]current page.south west) --
        ([xshift=-\MA@contentpage@footerrightmargin,yshift=\MA@layout@footerheight]current page.south east);
      \draw[academicblue,line width=0.9pt]
        ([xshift=\MA@contentpage@footerleftmargin,yshift=\MA@layout@footerheight]current page.south west) --
        ([xshift=.18\paperwidth,yshift=\MA@layout@footerheight]current page.south west);
    \end{tikzpicture}%
    \begin{beamercolorbox}[
        wd=\paperwidth,
        ht=\MA@footline@usedheight,
        dp=\MA@footline@useddepth
      ]{footline}
      \begin{academicfooter}
        {\usebeamerfont{footline}\MA@displayauthor\hfill\MA@displaytitle\hfill
        \usebeamercolor[fg]{page number in head/foot}\insertframenumber\,/\,\inserttotalframenumber\par}%
      \end{academicfooter}%
    \end{beamercolorbox}%
  \fi
}

\AtBeginSection[]{%
  \ifMA@sectionframe
    \begin{frame}[plain,noframenumbering]
      \MA@setlayoutregions{\MA@sectionpage@headerratio}{\MA@sectionpage@bodyratio}{\MA@sectionpage@footerratio}%
      \MA@setlayoutcontentwidth{\MA@sectionpage@bodyleftmargin}{\MA@sectionpage@bodyrightmargin}%
      \setlength{\MA@sectionrulex}{\dimexpr\MA@sectionpage@bodyleftmargin+.30\MA@layout@contentwidth\relax}%
      \setlength{\MA@sectiontextx}{\dimexpr\MA@sectionrulex+8mm\relax}%
      \setlength{\MA@sectiontextwidth}{\dimexpr\paperwidth-\MA@sectiontextx-\MA@sectionpage@bodyrightmargin\relax}%
      \setlength{\MA@sectionliney}{.31\paperheight}%
      \settowidth{\MA@sectiontitlewidth}{\sffamily\bfseries\fontsize{24}{28}\selectfont\insertsectionhead}%
      \ifdim\MA@sectiontitlewidth>\MA@sectiontextwidth
        \setlength{\MA@sectiontitlewidth}{\MA@sectiontextwidth}%
      \fi
      \begin{tikzpicture}[remember picture,overlay]
        \fill[MA@canvas] (current page.south west) rectangle (current page.north east);
        \fill[academicblue] (current page.north west) rectangle ([xshift=3.2mm]current page.south west);
        \fill[academicblue!6] ([xshift=3.2mm]current page.south west) rectangle ([xshift=\MA@sectionrulex]current page.north west);
        \draw[academicblue!20,line width=0.6pt]
          ([xshift=\MA@sectionrulex]current page.south west) --
          ([xshift=\MA@sectionrulex]current page.north west);
        \node[anchor=south east,inner sep=0pt,outer sep=0pt]
          at ([xshift={\dimexpr\MA@sectionrulex+0.6mm\relax}]current page.south west) {%
            \scalebox{0.88}[1]{%
              \ifXeTeX
                \sffamily\mdseries
              \else
                \fontfamily{phv}\fontseries{m}\selectfont
              \fi
              \fontsize{220}{220}\selectfont\color{academicblue!95}\insertsectionnumber%
            }%
          };
        \node[anchor=south west,inner sep=0pt,outer sep=0pt]
          at ([xshift=\MA@sectiontextx,yshift=\dimexpr\MA@sectionliney+1.1em\relax]current page.south west) {%
            \begin{minipage}{\MA@sectiontextwidth}
              \raggedright
              {\sffamily\bfseries\fontsize{24}{28}\selectfont\color{MA@ink}\insertsectionhead\par}
            \end{minipage}%
          };
        \draw[academicblue,line width=1.2pt]
          ([xshift=\MA@sectiontextx,yshift=\MA@sectionliney]current page.south west) --
          ([xshift=\dimexpr\MA@sectiontextx+\MA@sectiontitlewidth\relax,yshift=\MA@sectionliney]current page.south west);
        \node[anchor=north west,inner sep=0pt,outer sep=0pt]
          at ([xshift=\MA@sectiontextx,yshift=\dimexpr\MA@sectionliney-0.65em\relax]current page.south west) {%
            {\sffamily\bfseries\footnotesize\color{academicblue}\MakeUppercase{\MA@section@label}}%
          };
        \ifMA@sectionpage@header
          \MA@setlayoutcontentwidth{\MA@sectionpage@headerleftmargin}{\MA@sectionpage@headerrightmargin}%
          \draw[academicblue!18,line width=0.5pt]
            ([xshift=\MA@sectionpage@headerleftmargin,yshift=-\MA@layout@headerheight]current page.north west) --
            ([xshift=-\MA@sectionpage@headerrightmargin,yshift=-\MA@layout@headerheight]current page.north east);
          \node[anchor=north west,inner sep=0pt]
            at ([xshift=\MA@sectionpage@headerleftmargin]current page.north west) {%
              \begin{minipage}[c][\MA@layout@headerheight][c]{\MA@layout@contentwidth}
                {\usebeamerfont{footline}\bfseries\color{academicblue}\MA@displaytitle\par}%
              \end{minipage}%
            };
        \fi
        \ifMA@sectionpage@footer
          \MA@setlayoutcontentwidth{\MA@sectionpage@footerleftmargin}{\MA@sectionpage@footerrightmargin}%
          \draw[MA@softline,line width=0.45pt]
            ([xshift=\MA@sectionpage@footerleftmargin,yshift=\MA@layout@footerheight]current page.south west) --
            ([xshift=-\MA@sectionpage@footerrightmargin,yshift=\MA@layout@footerheight]current page.south east);
          \node[anchor=south west,inner sep=0pt]
            at ([xshift=\MA@sectionpage@footerleftmargin]current page.south west) {%
              \begin{minipage}[c][\MA@layout@footerheight][c]{\MA@layout@contentwidth}
                {\usebeamerfont{footline}\color{MA@muted}\MA@displayauthor\hfill\MA@displaytitle\par}%
              \end{minipage}%
            };
        \fi
      \end{tikzpicture}
    \end{frame}
  \fi
}

\newcommand{\tailpage}[2][]{%
  \begin{frame}[plain,noframenumbering]
    \MA@setlayoutregions{\MA@tailpage@headerratio}{\MA@tailpage@bodyratio}{\MA@tailpage@footerratio}%
    \begin{tikzpicture}[remember picture,overlay]
      \fill[MA@canvas] (current page.south west) rectangle (current page.north east);
      \fill[academicblue] (current page.north west) rectangle ([xshift=3.2mm]current page.south west);
      \ifMA@tailpage@header
        \MA@setlayoutcontentwidth{\MA@tailpage@headerleftmargin}{\MA@tailpage@headerrightmargin}%
        \draw[academicblue!18,line width=0.5pt]
          ([xshift=\MA@tailpage@headerleftmargin,yshift=-\MA@layout@headerheight]current page.north west) --
          ([xshift=-\MA@tailpage@headerrightmargin,yshift=-\MA@layout@headerheight]current page.north east);
        \node[anchor=north west,inner sep=0pt]
          at ([xshift=\MA@tailpage@headerleftmargin]current page.north west) {%
            \begin{minipage}[c][\MA@layout@headerheight][c]{\MA@layout@contentwidth}
              {\usebeamerfont{footline}\bfseries\color{academicblue}\MA@displaytitle\par}%
            \end{minipage}%
          };
      \fi
      \ifMA@tailpage@footer
        \MA@setlayoutcontentwidth{\MA@tailpage@footerleftmargin}{\MA@tailpage@footerrightmargin}%
        \draw[MA@softline,line width=0.45pt]
          ([xshift=\MA@tailpage@footerleftmargin,yshift=\MA@layout@footerheight]current page.south west) --
          ([xshift=-\MA@tailpage@footerrightmargin,yshift=\MA@layout@footerheight]current page.south east);
        \node[anchor=south west,inner sep=0pt]
          at ([xshift=\MA@tailpage@footerleftmargin]current page.south west) {%
            \begin{minipage}[c][\MA@layout@footerheight][c]{\MA@layout@contentwidth}
              {\usebeamerfont{footline}\color{MA@muted}\MA@displayauthor\hfill\MA@displaytitle\par}%
            \end{minipage}%
          };
      \fi
    \end{tikzpicture}
    \vspace*{\MA@layout@headerheight}
    \MA@setlayoutcontentwidth{\MA@tailpage@bodyleftmargin}{\MA@tailpage@bodyrightmargin}%
    \hspace*{\MA@tailpage@bodyleftmargin}%
    \begin{minipage}[c][\MA@layout@bodyheight][c]{\MA@layout@contentwidth}
      \centering
      \ifstrempty{#1}{}{%
        {\usebeamerfont{title}\usebeamercolor[fg]{title}#1\par}%
        \vspace{1.2em}%
      }%
      {\usebeamerfont{subtitle}\usebeamercolor[fg]{subtitle}#2\par}%
    \end{minipage}
  \end{frame}
}

\makeatother

\mode<all>

\endinput
