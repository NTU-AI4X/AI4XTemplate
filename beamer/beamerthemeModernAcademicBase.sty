\definecolor{academicblue}{HTML}{1a2a6c}
\definecolor{linkblue}{HTML}{1a2a6c}
\definecolor{citegreen}{HTML}{2d5a27}
\definecolor{urlpurple}{HTML}{5c3566}
\definecolor{abstractbg}{HTML}{f8f9fa}
\definecolor{abstractborder}{HTML}{e9ecef}
\definecolor{MA@canvas}{HTML}{fbfcfe}
\definecolor{MA@ink}{HTML}{182033}
\definecolor{MA@muted}{HTML}{65758b}
\definecolor{MA@softline}{HTML}{dfe6ef}
\definecolor{MA@panel}{HTML}{ffffff}

\newcommand{\MA@applybeamercolors}{%
  \setbeamercolor{normal text}{fg=MA@ink,bg=MA@panel}%
  \setbeamercolor{structure}{fg=academicblue}%
  \setbeamercolor{title}{fg=academicblue,bg=}%
  \setbeamercolor{subtitle}{fg=MA@muted,bg=}%
  \setbeamercolor{author}{fg=MA@ink,bg=}%
  \setbeamercolor{institute}{fg=MA@muted,bg=}%
  \setbeamercolor{date}{fg=MA@muted,bg=}%
  \setbeamercolor{frametitle}{fg=academicblue,bg=MA@canvas}%
  \setbeamercolor{framesubtitle}{fg=MA@muted,bg=MA@canvas}%
  \setbeamercolor{headline}{fg=MA@muted,bg=MA@canvas}%
  \setbeamercolor{footline}{fg=MA@muted,bg=MA@canvas}%
  \setbeamercolor{page number in head/foot}{fg=academicblue,bg=MA@canvas}%
  \setbeamercolor{block title}{fg=white,bg=academicblue}%
  \setbeamercolor{block body}{fg=MA@ink,bg=academicblue!5}%
  \setbeamercolor{block title alerted}{fg=white,bg=red!70!black}%
  \setbeamercolor{block body alerted}{fg=MA@ink,bg=red!6}%
  \setbeamercolor{block title example}{fg=white,bg=citegreen}%
  \setbeamercolor{block body example}{fg=MA@ink,bg=citegreen!7}%
  \setbeamercolor{caption name}{fg=academicblue}%
  \setbeamercolor{bibliography entry author}{fg=academicblue}%
  \hypersetup{%
    colorlinks=true,
    linkcolor=linkblue,
    citecolor=citegreen,
    urlcolor=urlpurple
  }%
}

% Usage: \setthemecolor{b91c1c} (hex) or \setthemecolor{185,28,28} (RGB)
\newcommand{\setthemecolor}[1]{%
  \IfSubStr{#1}{,}{%
    \definecolor{academicblue}{RGB}{#1}%
    \definecolor{linkblue}{RGB}{#1}%
  }{%
    \definecolor{academicblue}{HTML}{#1}%
    \definecolor{linkblue}{HTML}{#1}%
  }%
  \MA@applybeamercolors
}

\newcommand{\setlinkcolor}[1]{%
  \definecolor{linkblue}{HTML}{#1}%
  \MA@applybeamercolors
}
\newcommand{\setcitecolor}[1]{%
  \definecolor{citegreen}{HTML}{#1}%
  \MA@applybeamercolors
}
\newcommand{\seturlcolor}[1]{%
  \definecolor{urlpurple}{HTML}{#1}%
  \MA@applybeamercolors
}

