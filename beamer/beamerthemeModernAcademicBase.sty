% Layout presets.
% standard: balanced academic-team style; good default for talks and reports.
% compact: shorter header/footer; keeps more vertical space for normal slides.
% dense: minimum chrome; useful for equations, tables, and content-heavy decks.
% spacious: larger margins and breathing room; suited to keynote-style decks.
\newcommand{\modernacademiclayoutstandard}{%
  \setslidemargins{9mm}{9mm}%
  \settitlepagelayout{0}{1}{0}{9mm}{9mm}%
  \setsectionpagelayout{0.12}{0.78}{0.10}{9mm}{9mm}%
  \setcontentpagelayout{0.09}{0.83}{0.08}{9mm}{9mm}%
  \settailpagelayout{0.12}{0.78}{0.10}{9mm}{9mm}%
  \settitlepageheaderlayout{2.4em}{0pt}{12mm}{0.16\paperheight}%
  \setcontentheaderlayout{7.2mm}{2.0mm}{7.4mm}{2.0mm}{2.4mm}{1.2mm}{3.4mm}%
  \setfooterlayout{3.4ex}{1.2ex}%
}
\newcommand{\modernacademiclayoutcompact}{%
  \setslidemargins{8mm}{8mm}%
  \settitlepagelayout{0}{1}{0}{8mm}{8mm}%
  \setsectionpagelayout{0.10}{0.82}{0.08}{8mm}{8mm}%
  \setcontentpagelayout{0.08}{0.85}{0.07}{8mm}{8mm}%
  \settailpagelayout{0.10}{0.82}{0.08}{8mm}{8mm}%
  \settitlepageheaderlayout{2.2em}{0pt}{10mm}{0.13\paperheight}%
  \setcontentheaderlayout{6.4mm}{1.6mm}{6.6mm}{1.6mm}{2.0mm}{0.9mm}{2.8mm}%
  \setfooterlayout{3.0ex}{0.9ex}%
}
\newcommand{\modernacademiclayoutdense}{%
  \setslidemargins{6mm}{6mm}%
  \settitlepagelayout{0}{1}{0}{6mm}{6mm}%
  \setsectionpagelayout{0.09}{0.85}{0.06}{6mm}{6mm}%
  \setcontentpagelayout{0.07}{0.87}{0.06}{6mm}{6mm}%
  \settailpagelayout{0.09}{0.85}{0.06}{6mm}{6mm}%
  \settitlepageheaderlayout{2.0em}{0pt}{8mm}{0.11\paperheight}%
  \setcontentheaderlayout{5.8mm}{1.3mm}{6.0mm}{1.3mm}{1.7mm}{0.6mm}{2.4mm}%
  \setfooterlayout{2.7ex}{0.7ex}%
}
\newcommand{\modernacademiclayoutspacious}{%
  \setslidemargins{11mm}{11mm}%
  \settitlepagelayout{0}{1}{0}{11mm}{11mm}%
  \setsectionpagelayout{0.14}{0.76}{0.10}{11mm}{11mm}%
  \setcontentpagelayout{0.11}{0.80}{0.09}{11mm}{11mm}%
  \settailpagelayout{0.14}{0.76}{0.10}{11mm}{11mm}%
  \settitlepageheaderlayout{2.8em}{0pt}{15mm}{0.18\paperheight}%
  \setcontentheaderlayout{8.6mm}{2.4mm}{8.8mm}{2.4mm}{3.0mm}{1.4mm}{3.8mm}%
  \setfooterlayout{3.8ex}{1.4ex}%
}
\newcommand{\usemodernacademiclayout}[1]{%
  \IfStrEqCase{#1}{%
    {standard}{\modernacademiclayoutstandard}%
    {compact}{\modernacademiclayoutcompact}%
    {dense}{\modernacademiclayoutdense}%
    {spacious}{\modernacademiclayoutspacious}%
  }[\PackageWarning{beamerthemeModernAcademicBase}{Unknown layout preset `#1'. Keeping the current layout.}]%
}
\newcommand{\usebeamerlayoutpreset}[1]{\usemodernacademiclayout{#1}}

\usemodernacademiclayout{standard}

