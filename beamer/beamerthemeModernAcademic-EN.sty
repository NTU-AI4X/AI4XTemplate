%% beamerthemeModernAcademic-EN.sty
%% ModernAcademic Beamer theme for English academic presentations.
%% Designed for pdfLaTeX compilation.
%% License: MIT

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerthemeModernAcademic-EN}[2026/05/18 v1.0 ModernAcademic Beamer Theme (English)]

%% ============================================================================
%% 1. THEME ROLE
%% ============================================================================

% English Beamer wrapper for the shared ModernAcademic presentation foundation.
% This file keeps the English theme defaults in one place, following the same
% front-loaded configuration style as ModernAcademic-EN.cls. Users can still
% override any public command in the .tex preamble after \usetheme.

%% ============================================================================
%% 2. REQUIRED PACKAGES
%% ============================================================================

% Encoding for pdfLaTeX.
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}

% Mathematics.
\RequirePackage{amsmath}
\RequirePackage{amssymb}

% Fonts aligned with ModernAcademic-EN.cls.
\RequirePackage{inter}
\RequirePackage{newpxtext}
\RequirePackage{newpxmath}
\RequirePackage[varqu,varl]{inconsolata}

%% ============================================================================
%% 3. SHARED BEAMER THEME FOUNDATION
%% ============================================================================

\RequirePackage{beamerthemeModernAcademicBase}

%% ============================================================================
%% 4. TEMPLATE COLOR CONFIGURATION
%% ============================================================================

% Primary academic accent color used by titles, structural elements, frame rules,
% block headers, and internal links. Accepts HTML hex without # or RGB triplets.
\setthemecolor{1a2a6c}

% Functional hyperlink colors, matching the paper-class interface.
\setlinkcolor{1a2a6c} % Internal links and Beamer navigation hyperlinks.
\setcitecolor{2d5a27} % Citation links.
\seturlcolor{5c3566}  % URL links.

%% ============================================================================
%% 5. TEMPLATE LAYOUT CONFIGURATION
%% ============================================================================

% Layout presets:
%   standard: Balanced academic-team layout; recommended default.
%   compact:  Shorter header/footer for ordinary content-heavy slides.
%   dense:    Minimum chrome for equations, tables, algorithms, and dense decks.
%   spacious: Larger margins and breathing room for keynote-style presentations.
\usemodernacademiclayout{standard}

% Page-type area layouts.
%   title page:   Opening/title slide generated by \titlepage.
%   section page: Automatic divider slide generated at each \section.
%   content page: Ordinary chapter/body frames.
%   tail page:    Closing slides such as thanks, contact, and profile pages.
% Arguments:
%   {header ratio}{body ratio}{footer ratio}
%   {header left}{header right}{body left}{body right}{footer left}{footer right}
\settitlepageregionlayout{0}{1}{0}{10mm}{10mm}{10mm}{10mm}{2.5mm}{2.5mm}
\setsectionpageregionlayout{0.15}{0.75}{0.05}{10mm}{10mm}{10mm}{10mm}{2.5mm}{2.5mm}
\setcontentpageregionlayout{0.1}{0.85}{0.05}{2.5mm}{2.5mm}{2.5mm}{2.5mm}{2.5mm}{2.5mm}
\settailpageregionlayout{0}{1}{0}{10mm}{10mm}{10mm}{10mm}{2.5mm}{2.5mm}

% Header/footer switches for each page type.
\hidetitlepageheader
\hidetitlepagefooter
\hidesectionpageheader
\hidesectionpagefooter
\showcontentpageheader
\showcontentpagefooter
\hidetailpageheader
\hidetailpagefooter

% Optional fine-grained header/footer tuning remains available, but page-type
% ratios above are the primary layout interface.
\settitlepageheaderlayout{3em}{3pt}{2pt}{3pt}
\setcontentheaderlayout{3em}{1.5ex}{2em}{1ex}{0.8ex}{1.2mm}{3.2mm}
\setfooterlayout{3.4ex}{1.2ex}

%% ============================================================================
%% 6. TITLE LOGO CONFIGURATION
%% ============================================================================

% Optional template name retained for user metadata. The default title page does
% not render it because left-aligned title slides keep the chrome minimal.
\templatename{ModernAcademic-EN\\Beamer Theme}

% Reusable logo content. If the bundled logo is available, show it on the title
% slide lower-right by default. Users may replace it with \titlelogocontent.
\IfFileExists{../assets/logo.png}{%
    \titlelogocontent{\includegraphics[height=2.4em]{../assets/logo.png}}%
    \showlogointitle
}{%
    \hidelogointitle
}
\hidelogoinheader

% Gap retained for compatibility with custom title-page arrangements.
\settitlelogogap{1em}

%% ============================================================================
%% 7. SECTION DIVIDER CONFIGURATION
%% ============================================================================

% Label shown on automatic section divider slides.
\setsectionname{Section}

% Insert an automatic divider slide at each \section.
\showsectionframes

%% ============================================================================
%% 8. ENGLISH LABEL DEFAULTS
%% ============================================================================

\setabstractname{Abstract}

\endinput
